{
  "expo": {
    "name": "Vice",
    "slug": "vices",
    "scheme": "vice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1713"
    },
    "ios": {
      "bundleIdentifier": "com.logsaturn.vice",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Vice uses your location to point you toward the nearest place to satisfy your vice.",
        "NSMotionUsageDescription": "Vice uses motion sensors to power the live compass needle."
      }
    },
    "android": {
      "package": "com.logsaturn.vice",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c1713"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-updates"
    ],
    "updates": {
      "url": "https://u.expo.dev/f978a440-4380-4b9a-8aa2-e970d17b31fd"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f978a440-4380-4b9a-8aa2-e970d17b31fd"
      }
    },
    "owner": "sirhobbys-organization"
  }
}
