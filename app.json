{
  "expo": {
    "name": "Vice",
    "slug": "vices",
    "scheme": "vice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1713"
    },
    "ios": {
      "bundleIdentifier": "com.logsaturn.vice",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Vice uses your location to point you toward the nearest place to satisfy your vice.",
        "NSMotionUsageDescription": "Vice uses motion sensors to power the live compass needle."
      }
    },
    "android": {
      "package": "com.logsaturn.vice",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c1713"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-updates",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vice needs photo library access to update your profile picture.",
          "cameraPermission": "Vice needs camera access to take a profile picture."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/07f1038b-528c-4d19-b078-3418f3732620"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "07f1038b-528c-4d19-b078-3418f3732620"
      }
    },
    "owner": "sirhobbys-organization"
  }
}
